# zlib
local zlibBasePackage = zlib ;
local zlibDevelPackage = zlib_devel ;
local zlibSourcePackage = zlib_source ;
if ! [ IsPackageAvailable $(zlibDevelPackage) ] {
	if [ IsPackageAvailable zlib_bootstrap_devel ] || [ Glob
		[ FDirName $(HAIKU_OUTPUT_DIR) build_packages ]
		: zlib_bootstrap_devel-* ] {
		zlibBasePackage = zlib_bootstrap ;
		zlibDevelPackage = zlib_bootstrap_devel ;
		zlibSourcePackage = zlib_bootstrap_source ;
	}
}
if [ IsPackageAvailable $(zlibDevelPackage) ]
	|| $(zlibDevelPackage) = zlib_bootstrap_devel {
	ExtractBuildFeatureArchives zlib :
		file: base $(zlibBasePackage)
			runtime: lib
		file: devel $(zlibDevelPackage)
			depends: base
			library: $(developLibDir)/libz.so
			headers: $(developHeadersDir)
		# sources are required for the primary architecture only
		primary @{
			file: source $(zlibSourcePackage)
				sources: develop/sources/%portRevisionedName%/sources
		}@
		;

	EnableBuildFeatures zlib ;
} else {
	unavailableBuildFeatures += zlib ;
}


