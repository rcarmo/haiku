SubDir HAIKU_TOP src apps packageinstaller ;

UsePrivateHeaders shared interface ;
UseBuildFeatureHeaders zlib ;

#SEARCH_SOURCE += [ FDirName $(HAIKU_TOP) src kits interface ] ;

local zlibHeaders = [ BuildFeatureAttribute zlib : headers ] ;
local zlibLibrary = [ BuildFeatureAttribute zlib : library ] ;
if ! $(zlibHeaders) {
	zlibHeaders = [ FDirName $(HAIKU_OUTPUT_DIR) build_packages
		zlib_bootstrap-1.2.13-1-arm64 develop headers ] ;
}
if ! $(zlibLibrary) {
	zlibLibrary = [ FDirName $(HAIKU_OUTPUT_DIR) build_packages
		zlib_bootstrap-1.2.13-1-arm64 lib libz.so.1 ] ;
}

UseHeaders $(zlibHeaders) : true ;
Includes [ FGristFiles PackageItem.cpp ] : $(zlibHeaders) ;

Application LegacyPackageInstaller :
	main.cpp
	BlockingWindow.cpp
	PackageWindow.cpp
	PackageView.cpp
	PackageInfo.cpp
	PackageItem.cpp
	PackageInstall.cpp
	PackageStatus.cpp
	PackageTextViewer.cpp
	PackageImageViewer.cpp
	InstalledPackageInfo.cpp
	UninstallWindow.cpp
	UninstallView.cpp
	: be localestub tracker translation shared
		$(zlibLibrary)
		[ TargetLibsupc++ ]
	: PackageInstaller.rdef
;

DoCatalogs LegacyPackageInstaller :
	x-vnd.Haiku-PackageInstaller
	:
	main.cpp
	PackageImageViewer.cpp
	PackageInfo.cpp
	PackageInstall.cpp
	PackageItem.cpp
	PackageStatus.cpp
	PackageTextViewer.cpp
	PackageView.cpp
	PackageWindow.cpp
	UninstallWindow.cpp
	UninstallView.cpp
;
